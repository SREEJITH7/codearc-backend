							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Client → Server: Login with credentials Server → Client: Access Token (JWT, Bearer token) Client → Server: Each request includes token in Authorization header Server: Validates token signature (no DB lookup)"
