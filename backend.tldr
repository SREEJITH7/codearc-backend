												{
													"type": "text",
													"marks": [
														{
															"type": "bold"
														}
													],
													"text": "Use unique key names"
												},
												{
													"type": "text",
													"text": ": Prefix with your app name ("
												},
												{
													"type": "text",
													"marks": [
														{
															"type": "code"
														}
													],
													"text": "github:state:"
												},
												{
													"type": "text",
													"text": ")"
												}
											]
										}
									]
								},
								{
									"type": "listItem",
									"content": [
										{
											"type": "paragraph",
											"attrs": {
												"dir": "auto"
											},
											"content": [
												{
													"type": "text",
													"marks": [
														{
															"type": "bold"
														}
													],
													"text": "Set appropriate TTL"
												},
												{
													"type": "text",
													"text": ": 5-10 minutes is usually sufficient"
												}
											]
										}
									]
								},
								{
									"type": "listItem",
									"content": [
										{
