										{
											"type": "bold"
										}
									],
									"text": "🛠️ Main Bottlenecks & Bugs (Karanam & Pariharam)"
								}
							]
						},
						{
							"type": "heading",
							"attrs": {
								"dir": "auto",
								"level": 3
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "bold"
										}
									],
									"text": "1. The HttpOnly Cookie Trap 🛡️"
								}
							]
						},
						{
							"type": "bulletList",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
