		{
			"x": -815.3835248931515,
			"y": 472.30178058607913,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:z64kHZdYSx9K-eWeAoNRZ",
			"type": "text",
			"props": {
				"color": "black",
				"size": "m",
				"w": 867.2000122070312,
				"font": "draw",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1.7044080663201746,
				"richText": {
					"type": "doc",
					"content": [
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "Redis Server Architecture:\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "┌─────────────────────────────────────────────────┐\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│               Redis Process                      │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  ┌─────────────────────────────────────────┐    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   In-Memory Data Store (RAM)            │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   • Strings, Lists, Hashes, Sets        │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   • All data stays in memory            │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  └─────────────────────────────────────────┘    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│                   ↑                              │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│    Single-threaded event loop ←─┐               │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│    (processes commands one by one)               │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│                   ↓                              │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  ┌─────────────────────────────────────────┐    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   Persistence Layer (Optional)          │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   • RDB snapshots                       │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  │   • AOF logs                            │    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "│  └─────────────────────────────────────────┘    │\r"
								}
							]
						},
						{
							"type": "paragraph",
							"content": [
								{
									"type": "text",
									"text": "└─────────────────────────────────────────────────┘"
								}
							]
						}
					]
				}
			},
